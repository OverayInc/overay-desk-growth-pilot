STEAM_APP_ID=0
# Optional fallback. Prefer managing this in the web Settings page.
STEAM_FINANCIAL_API_KEY=
# Required for real web-managed secrets. Keep this stable after saving keys.
KEY_ENCRYPTION_SECRET=change-this-before-real-key-storage

# Optional SMTP fallback. Prefer managing this in the web Settings page.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_STARTTLS=true
EMAIL_FROM=
EMAIL_REPLY_TO=
EMAIL_SEND_MODE=smtp

# ---- AI marketing agent (self-hosted Gemma 4 on the LAN GPU box) ----
# vLLM OpenAI-compatible endpoint. Default is the box's LAN IP — give the box a
# static IP (Proxmox cloud-init / router DHCP reservation) so it stays valid.
# (overay.local works from a browser but NOT from Node's fetch, so use the IP.)
# Start the model with `~/gemma4/gemma4.sh up` on the GPU host.
LP_AI_BASE_URL=http://192.168.50.107:8000/v1
LP_AI_MODEL=gemma-4-26b-a4b
# vLLM ignores auth by default; set only if you put a gateway in front.
LP_AI_API_KEY=
LP_AI_TIMEOUT_MS=60000

DISABLE_SYNC_SCHEDULER=false
SYNC_SCHEDULER_INTERVAL_MS=60000

# ---- Creator discovery bot (finds creators to email; gemma4 = analyzer) ----
# The bot SEARCHES via these APIs, then gemma4 extracts email + classifies the
# channel. It only fills a review queue — it never auto-sends mail. Every source
# is optional; whatever is unset is skipped. Try it standalone:
#   node src/discovery/run.mjs --dry "spot the anomaly game"
#
# YouTube Data API v3 key (reused from the YouTube stats integration above).
YOUTUBE_API_KEY=
# Twitch app credentials (client-credentials grant) for streamer discovery.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# General web search: provider is "brave" or "serpapi"; key from that provider.
WEB_SEARCH_PROVIDER=
WEB_SEARCH_API_KEY=
# Seed search queries, |-separated. Blank = built-in anomaly-game defaults.
LP_DISCOVERY_SEEDS=
# Optional: bias YouTube results to a region (e.g. KR, US). Blank = global.
LP_DISCOVERY_REGION=
# Optional: override the game description gemma scores "fit" against.
LP_DISCOVERY_GAME_CONTEXT=
# Hybrid mode (gemma "in the loop"): query-expansion count + lead-following hops.
DISCOVERY_EXPAND_COUNT=8
DISCOVERY_LEAD_DEPTH=2
# Optional headless-browser email harvesting for JS-rendered contact pages.
# Needs: npm i -D playwright && npx playwright install chromium
DISCOVERY_USE_RENDERER=false
# Nightly window scheduler (server). Off by default; set false to enable. While
# inside the window it runs continuously until the end time, re-seeding via gemma.
DISABLE_DISCOVERY_SCHEDULER=true
DISCOVERY_WINDOW_START=02:00
DISCOVERY_WINDOW_END=09:00
# How long each incremental save chunk runs (ms). Lower = more frequent saves.
DISCOVERY_CHUNK_MS=300000

# ---- Microsoft (Azure AD / Entra ID) login — company-account access ----
# Auth turns ON only when MS_CLIENT_ID and AUTH_ALLOWED_EMAILS are both set
# (so local dev / CI stay open). Force with AUTH_ENABLED=true|false.
# See docs/auth-setup.md for the one-time Azure App Registration steps.
#
# Azure App Registration "Application (client) ID" for THIS app (public, not a secret):
MS_CLIENT_ID=
# Company tenant (Directory ID). Default is the Overay tenant.
MS_TENANT_ID=f1f0a729-25be-432c-b9c9-24775c52aa1a
# Access control — set EITHER (or both). Auth turns on when MS_CLIENT_ID plus
# at least one of these is present.
#
# "All company employees": allow a whole domain (comma-separated). Not secret —
# fine in the ConfigMap. Single-tenant + server tid check already limits to the
# company directory; the domain also excludes guest accounts.
AUTH_ALLOWED_DOMAIN=overay.com
# "Executives only" (narrower): explicit emails. Put these in a SealedSecret so
# the list is never visible in source / GitOps. Leave blank to rely on domain.
AUTH_ALLOWED_EMAILS=
# Optional override: true forces enforcement (fails closed), false disables it.
# AUTH_ENABLED=true
